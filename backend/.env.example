# ─────────────────────────────────────────────────────────────────────────────
# Money Muling Detection System – environment variables
#
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection URI
# Format: postgresql://[user]:[password]@[host]:[port]/[dbname]?sslmode=require
#
# ── Neon (recommended) ──────────────────────────────────────────────────────
# Direct connection (no pooling, best for long-running processes / migrations):
#   postgresql://[user]:[password]@[host].neon.tech/[dbname]?sslmode=require
# Pooled connection via PgBouncer (lower connection overhead, set PGBOUNCER_MODE=1):
#   postgresql://[user]:[password]@[host]-pooler.neon.tech/[dbname]?sslmode=require
#
# ── Local development ───────────────────────────────────────────────────────
#   postgresql://postgres:password@localhost:5432/vingoo
DATABASE_URL=postgresql://[user]:[password]@[host].neon.tech/[dbname]?sslmode=require

# Set to 1 ONLY when DATABASE_URL points at Neon's *pooled* host (port 6432 /
# -pooler hostname).  Tells SQLAlchemy to use NullPool + disable prepared
# statements, which is required by PgBouncer transaction mode.
PGBOUNCER_MODE=0

# SSL mode for the database connection.
# "require" for all cloud providers (Neon, Railway, Render, etc.).
# "disable" for local Postgres only.
DB_SSL_MODE=require

# Comma-separated list of allowed frontend origins.
# Set this to your Vercel deployment URL once deployed.
# Example: https://vingoo.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# ─────────────────────────────────────────────────────────────────────────────
# AI Explanation Layer – OpenRouter
# Get your key at: https://openrouter.ai/keys
# Leave blank to disable AI explanations (detection still works normally).
# ─────────────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-YOUR-KEY-HERE
