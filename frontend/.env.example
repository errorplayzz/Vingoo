# ─────────────────────────────────────────────────────────────────
#  VINGOO — Environment Variables
#  Copy this file to .env and fill in your Firebase project values.
# ─────────────────────────────────────────────────────────────────
#
#  Where to find these values:
#  1. Go to https://console.firebase.google.com
#  2. Create / open your project
#  3. Click the </> (Web) icon to register a web app
#  4. Copy each value from the "firebaseConfig" object shown
#
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# Backend API URL
# Local dev: http://localhost:8000
# Production: https://your-service.up.railway.app  ← paste your Railway URL here
VITE_API_URL=http://localhost:8000
